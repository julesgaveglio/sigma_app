# ─── Base ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
VITE_APP_ID=sigma-crm
JWT_SECRET=your-jwt-secret-here-min-32-chars

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/sigma_crm

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── S3 Storage ───────────────────────────────────────────────────────────────
# Leave empty to use local filesystem storage (.storage/ directory)
S3_BUCKET=
S3_REGION=eu-west-3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For S3-compatible services (Supabase Storage, MinIO, etc.):
S3_ENDPOINT=

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── LLM (OpenAI-compatible) ─────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

